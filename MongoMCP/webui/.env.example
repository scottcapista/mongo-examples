# Optional: Vite dev server proxy target (production build uses same-origin Flask)
# VITE_API_URL=

# LLM model label in chat UI
# VITE_LLM_MODEL_ID=claude-sonnet-4-6

# --- OIDC (register web app in Okta / Entra with Authorization Code + PKCE) ---
# Redirect URI (dev): http://localhost:8001/auth/callback
# OIDC_ISSUER=https://your-org.okta.com/oauth2/default
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:8001/auth/callback
# OIDC_SCOPES="openid profile email"
# SESSION_SECRET=change-me
# AUTH_REQUIRED=false
