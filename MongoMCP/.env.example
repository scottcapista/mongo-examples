IS_LOCAL=true
AWS_REGION=us-east-1
MCP_TOOL_NAME=AirbnbSearch

# Atlas DB user (host only — no mongodb+srv:// prefix)
MONGO_USERNAME=your-mongo-username
MONGO_PASSWORD=your-mongo-password
MONGO_URL=your-cluster.mongodb.net

VOYAGE_AI_KEY=your-voyage-api-key-here

# LLM: grove (MongoDB Grove gateway) or bedrock
LLM_PROVIDER=grove
GROVE_API_KEY=your-grove-api-key-here
# Or: ANTHROPIC_API_KEY=your-grove-api-key-here
ANTHROPIC_BASE_URL=https://grove-gateway-prod.azure-api.net/grove-foundry-prod/anthropic
ANTHROPIC_VERSION=2023-06-01
LLM_MODEL_ID=claude-sonnet-4-6
LLM_MAX_TOKENS=4096

# Filled automatically by scripts/local-setup.sh
MCP_AUTH_TOKEN=
